            </entry>
            <entry>
              <para>
                <codeEntityReference qualifyHint="false" autoUpgrade="true">M:XSharp.VFP.Functions.ShowFoxArray(XSharp.__Array,System.String)</codeEntityReference>
              </para>
            </entry>
            <entry>
              <para>Dump the contents of an array to the terminal window</para>
            </entry>
          </row>
          <row>
            <entry>
              <para>XSharp.RT</para>
            </entry>
            <entry>
              <para>
                <codeEntityReference qualifyHint="false" autoUpgrade="true">M:XSharp.RT.Functions.ShowObject(System.Object,System.String)</codeEntityReference>
              </para>
            </entry>
            <entry>
              <para>Dump the contents of an object to the terminal window</para>
            </entry>
          </row>
          <row>
            <entry>
              <para>XSharp.RT</para>
            </entry>
            <entry>
              <para>
                <codeEntityReference qualifyHint="false" autoUpgrade="true">M:XSharp.RT.Functions.ShowPrivates(System.Boolean)</codeEntityReference>
              </para>
            </entry>
            <entry>
              <para>Dump the currently defined privates to the terminal window</para>
