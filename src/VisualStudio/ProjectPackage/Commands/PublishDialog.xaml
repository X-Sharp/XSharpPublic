<Window x:Class="XSharp.Project.PublishDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
        mc:Ignorable="d"
        Title="Publish Project"
        Height="550"
        Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
    toolkit:Themes.UseVsTheme="True" >
    <Window.Resources>
        <ResourceDictionary Source="VsThemeDictionary.xaml"/>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Configuration -->
        <Label Grid.Row="0" Content="Configuration:" Margin="0,5,0,0"/>
        <ComboBox Grid.Row="1" x:Name="ConfigurationComboBox" Margin="0,5,0,0"
                  Text="{Binding Configuration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <ComboBoxItem Content="Debug"/>
            <ComboBoxItem Content="Release"/>
        </ComboBox>

        <!-- Target Framework -->
        <Label Grid.Row="2" Content="Target Framework:" Margin="0,10,0,0"/>
        <ComboBox Grid.Row="3" x:Name="TargetFrameworkComboBox" Margin="0,5,0,0"
                  IsEditable="True"
                  Text="{Binding TargetFramework, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Target Runtime -->
        <Label Grid.Row="4" Content="Target Runtime (RID):" Margin="0,10,0,0"/>
        <ComboBox Grid.Row="5" x:Name="RuntimeComboBox" Margin="0,5,0,0"
                  IsEditable="True"
                  Text="{Binding Runtime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <ComboBoxItem Content=""/>
            <ComboBoxItem Content="win-x64"/>
            <ComboBoxItem Content="win-x86"/>
            <ComboBoxItem Content="win-arm64"/>
            <ComboBoxItem Content="linux-x64"/>
            <ComboBoxItem Content="linux-arm64"/>
            <ComboBoxItem Content="osx-x64"/>
            <ComboBoxItem Content="osx-arm64"/>
        </ComboBox>

        <!-- Output Path -->
        <Label Grid.Row="6" Content="Output Path:" Margin="0,10,0,0"/>
        <Grid Grid.Row="7" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="OutputPathTextBox"
                     VerticalContentAlignment="Center"
                     Text="{Binding OutputPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Grid.Column="1" Content="Browse..." Width="80" Margin="5,0,0,0" Click="BrowseOutputPath_Click"/>
        </Grid>

        <!-- Options -->
        <GroupBox Grid.Row="8" Header="Publish Options" Margin="0,10,0,0" Padding="10">
            <StackPanel>
                <CheckBox x:Name="SelfContainedCheckBox" Content="Self-Contained Deployment" Margin="0,5,0,0"
                          IsChecked="{Binding SelfContained, Mode=TwoWay}"/>
                <CheckBox x:Name="SingleFileCheckBox" Content="Produce Single File" Margin="0,5,0,0"
                          IsChecked="{Binding SingleFile, Mode=TwoWay}"/>
                <CheckBox x:Name="ReadyToRunCheckBox" Content="Ready to Run" Margin="0,5,0,0"
                          IsChecked="{Binding ReadyToRun, Mode=TwoWay}"/>
                <CheckBox x:Name="TrimmedCheckBox" Content="Trim Unused Assemblies" Margin="0,5,0,0"
                          IsChecked="{Binding Trimmed, Mode=TwoWay}"/>
            </StackPanel>
        </GroupBox>

        <!-- Help Text -->
        <TextBlock Grid.Row="9" Margin="0,10,0,0" TextWrapping="Wrap" Foreground="Gray" FontSize="11">
            This will run 'dotnet publish' with the selected options.
            For Self-Contained deployment, a Runtime ID (RID) must be specified.
        </TextBlock>

        <!-- Buttons -->
        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Publish" Width="80" Height="25" Margin="0,0,10,0" Click="Publish_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="80" Height="25" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
