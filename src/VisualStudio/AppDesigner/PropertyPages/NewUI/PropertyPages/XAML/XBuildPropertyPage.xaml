<UserControl
    x:Class="XSharp.Project.XBuildPropertyPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:XSharp.Project"
    mc:Ignorable="d"
    d:DesignHeight="700" d:DesignWidth="700"
    UseLayoutRounding="True"
    toolkit:Themes.UseVsTheme="True"
    xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
    xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
    FontFamily="{DynamicResource {x:Static vsshell:VsFonts.EnvironmentFontFamilyKey}}"
    FontSize="{DynamicResource {x:Static vsshell:VsFonts.EnvironmentFontSizeKey}}">

    <!--
        Build property page - WPF/XAML implementation (SDK-style projects).
        DataContext: XBuildPropertyPageViewModel (set by XBuildPropertyPageXamlHost).

        Layout mirrors the WinForms XBuildPropertyPagePanel sections:
          Left column  - Output paths, Signing, Code generation, PPO, Define Constants
          Right column - Warnings, XML Documentation, Misc checkboxes, Command line, NoWarn
    -->

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/XSharp.AppDesigner2022;component/VsThemeDictionary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <local:BoolToVisibilityConverter x:Key="BoolToVisibility"        Invert="False"/>
            <local:BoolToVisibilityConverter x:Key="BoolToInverseVisibility" Invert="True"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel>

        <!-- Configuration selector -->
        <DockPanel DockPanel.Dock="Top" Margin="8,8,8,4" LastChildFill="False">
            <Label DockPanel.Dock="Left" Content="Configuration:" VerticalAlignment="Center" Padding="0,0,4,0"/>
            <ComboBox DockPanel.Dock="Left"
                      ItemsSource="{Binding ConfigSelector.ConfigNames}"
                      SelectedItem="{Binding ConfigSelector.SelectedConfig, Mode=TwoWay}"
                      Width="200" VerticalAlignment="Center"/>
        </DockPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="8,8,8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ============================================================ -->
            <!-- LEFT COLUMN                                                   -->
            <!-- ============================================================ -->
            <StackPanel Grid.Column="0" Margin="0,0,8,0">

                <!-- Output paths section -->
                <Label Content="Output" FontWeight="Bold" Margin="0,0,0,4"/>

                <!-- Output Path (read-only + browse + reset) -->
                <Label Content="{Binding CaptOutputPath}"
                       ToolTip="{Binding DescOutputPath}"
                       Margin="0,4,0,2"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding OutputPath, Mode=OneWay}"
                             IsReadOnly="True"
                             ToolTip="{Binding DescOutputPath}"/>
                    <Button Grid.Column="1" Content="..." Width="26" Margin="4,0,0,0"
                            ToolTip="{Binding DescOutputPath}"
                            Click="OnBrowseOutputPathClick"/>
                    <Button Grid.Column="2" Style="{DynamicResource ResetButtonStyle}"
                            Command="{Binding ResetCommand}" CommandParameter="OutputPath"
                            Margin="4,0,0,0"/>
                </Grid>

                <!-- Intermediate Output Path (read-only + browse + reset) -->
                <Label Content="{Binding CaptIntermediateOutputPath}"
                       ToolTip="{Binding DescIntermediateOutputPath}"
                       Margin="0,8,0,2"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding IntermediateOutputPath, Mode=OneWay}"
                             IsReadOnly="True"
                             ToolTip="{Binding DescIntermediateOutputPath}"/>
                    <Button Grid.Column="1" Content="..." Width="26" Margin="4,0,0,0"
                            ToolTip="{Binding DescIntermediateOutputPath}"
                            Click="OnBrowseIntermediateOutputPathClick"/>
                    <Button Grid.Column="2" Style="{DynamicResource ResetButtonStyle}"
                            Command="{Binding ResetCommand}" CommandParameter="IntermediateOutputPath"
                            Margin="4,0,0,0"/>
                </Grid>

                <!-- Platform -->
                <local:PropertyComboBox
                        Label="{Binding CaptPlatformTarget}"
                        Items="{Binding PlatformTargetValues}"
                        Value="{Binding PlatformTarget, Mode=TwoWay}"
                        PropertyName="PlatformTarget"
                        ToolTip="{Binding DescPlatformTarget}"
                        Margin="0,10,0,0"/>

                <!-- Code generation section -->
                <Label Content="Code Generation" FontWeight="Bold" Margin="0,12,0,4"/>

                <local:PropertyCheckBox
                        Label="{Binding CaptOptimize}"
                        Value="{Binding Optimize, Mode=TwoWay}"
                        PropertyName="Optimize"
                        ToolTip="{Binding DescOptimize}"
                        Margin="0,3,0,0"/>

                <local:PropertyCheckBox
                        Label="{Binding CaptPrefer32Bit}"
                        Value="{Binding Prefer32Bit, Mode=TwoWay}"
                        PropertyName="Prefer32Bit"
                        IsEnabled="{Binding Prefer32BitEnabled}"
                        ToolTip="{Binding DescPrefer32Bit}"
                        Margin="0,3,0,0"/>

                <local:PropertyCheckBox
                        Label="{Binding CaptRegisterForComInterop}"
                        Value="{Binding RegisterForComInterop, Mode=TwoWay}"
                        PropertyName="RegisterForComInterop"
                        ToolTip="{Binding DescRegisterForComInterop}"
                        Margin="0,3,0,0"/>

                <!-- Preprocessor section -->
                <Label Content="Preprocessor" FontWeight="Bold" Margin="0,12,0,4"/>

                <local:PropertyCheckBox
                        Label="{Binding CaptPPO}"
                        Value="{Binding PPO, Mode=TwoWay}"
                        PropertyName="PPO"
                        ToolTip="{Binding DescPPO}"
                        Margin="0,3,0,0"/>

                <!-- Define Constants -->
                <local:PropertyTextBox
                        Label="{Binding CaptDefineConstants}"
                        Value="{Binding DefineConstants, Mode=TwoWay}"
                        PropertyName="DefineConstants"
                        ToolTip="{Binding DescDefineConstants}"
                        Margin="0,10,0,0"/>

                <!-- Signing section -->
                <Label Content="Signing" FontWeight="Bold" Margin="0,12,0,4"/>

                <local:PropertyCheckBox
                        Label="{Binding CaptSignAssembly}"
                        Value="{Binding SignAssembly, Mode=TwoWay}"
                        PropertyName="SignAssembly"
                        ToolTip="{Binding DescSignAssembly}"
                        Margin="0,3,0,0"/>

                <local:PropertyCheckBox
                        Label="{Binding CaptDelaySign}"
                        Value="{Binding DelaySign, Mode=TwoWay}"
                        PropertyName="DelaySign"
                        ToolTip="{Binding DescDelaySign}"
                        Margin="0,3,0,0"/>

                <!-- Key File (read-only + browse + reset) -->
                <Label Content="{Binding CaptAssemblyOriginatorKeyFile}"
                       ToolTip="{Binding DescAssemblyOriginatorKeyFile}"
                       Margin="0,8,0,2"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding AssemblyOriginatorKeyFile, Mode=OneWay}"
                             IsReadOnly="True"
                             ToolTip="{Binding DescAssemblyOriginatorKeyFile}"/>
                    <Button Grid.Column="1" Content="..." Width="26" Margin="4,0,0,0"
                            ToolTip="{Binding DescAssemblyOriginatorKeyFile}"
                            Click="OnBrowseKeyFileClick"/>
                    <Button Grid.Column="2" Style="{DynamicResource ResetButtonStyle}"
                            Command="{Binding ResetCommand}" CommandParameter="AssemblyOriginatorKeyFile"
                            Margin="4,0,0,0"/>
                </Grid>

            </StackPanel>

            <!-- ============================================================ -->
            <!-- RIGHT COLUMN                                                  -->
            <!-- ============================================================ -->
            <StackPanel Grid.Column="1" Margin="8,0,0,0">

                <!-- Warnings section -->
                <Label Content="Warnings" FontWeight="Bold" Margin="0,0,0,4"/>

                <!-- Warning level -->
                <Label Content="{Binding CaptWarningLevel}"
                       ToolTip="{Binding DescWarningLevel}"
                       Margin="0,4,0,2"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0"
                              SelectedIndex="{Binding WarningLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              ToolTip="{Binding DescWarningLevel}">
                        <ComboBoxItem Content="0"/>
                        <ComboBoxItem Content="1"/>
                        <ComboBoxItem Content="2"/>
                        <ComboBoxItem Content="3"/>
                        <ComboBoxItem Content="4"/>
                    </ComboBox>
                    <Button Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                            Command="{Binding ResetCommand}" CommandParameter="WarningLevel"
                            Margin="4,0,0,0"/>
                </Grid>

                <!-- Treat warnings as errors radio group -->
                <Label Content="Treat warnings as errors:" Margin="0,10,0,2"/>
                <RadioButton Content="None"
                             IsChecked="{Binding WarningsModeNone, Mode=TwoWay}"
                             Margin="4,2,0,0"/>
                <RadioButton Content="All"
                             IsChecked="{Binding WarningsModeAll, Mode=TwoWay}"
                             Margin="4,2,0,0"/>
                <RadioButton Content="Specific warnings:"
                             IsChecked="{Binding WarningsModeSpecific, Mode=TwoWay}"
                             Margin="4,2,0,0"/>
                <local:PropertyTextBox
                        Value="{Binding SpecificWarnings, Mode=TwoWay}"
                        PropertyName="WarningsAsErrors"
                        IsEnabled="{Binding SpecificWarningsEnabled}"
                        ToolTip="{Binding DescSpecificWarnings}"
                        Margin="0,2,0,0"/>

                <!-- XML Documentation section -->
                <Label Content="XML Documentation" FontWeight="Bold" Margin="0,12,0,4"/>

                <local:PropertyCheckBox
                        Label="{Binding CaptDocumentationFile}"
                        Value="{Binding XmlDocEnabled, Mode=TwoWay}"
                        PropertyName="DocumentationFile"
                        ToolTip="{Binding DescDocumentationFile}"
                        Margin="0,3,0,0"/>

                <!-- Documentation file name - only shown when XmlDocEnabled -->
                <TextBox Text="{Binding DocumentationFile, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         ToolTip="{Binding DescDocumentationFileName}"
                         Visibility="{Binding XmlDocEnabled, Converter={StaticResource BoolToVisibility}}"
                         Margin="0,4,0,0"/>

                <!-- Misc section -->
                <Label Content="Miscellaneous" FontWeight="Bold" Margin="0,12,0,4"/>

                <local:PropertyCheckBox
                        Label="{Binding CaptUseSharedCompilation}"
                        Value="{Binding UseSharedCompilation, Mode=TwoWay}"
                        PropertyName="UseSharedCompilation"
                        ToolTip="{Binding DescUseSharedCompilation}"
                        Margin="0,3,0,0"/>

                <local:PropertyCheckBox
                        Label="{Binding CaptSuppressRCWarnings}"
                        Value="{Binding SuppressRCWarnings, Mode=TwoWay}"
                        PropertyName="SuppressRCWarnings"
                        ToolTip="{Binding DescSuppressRCWarnings}"
                        Margin="0,3,0,0"/>

                <!-- Command line options -->
                <local:PropertyTextBox
                        Label="{Binding CaptCommandLineOption}"
                        Value="{Binding CommandLineOption, Mode=TwoWay}"
                        PropertyName="CommandLineOption"
                        ToolTip="{Binding DescCommandLineOption}"
                        Margin="0,10,0,0"/>

                <!-- Suppress specific warnings -->
                <local:PropertyTextBox
                        Label="{Binding CaptNoWarn}"
                        Value="{Binding NoWarn, Mode=TwoWay}"
                        PropertyName="NoWarn"
                        ToolTip="{Binding DescNoWarn}"
                        Margin="0,8,0,0"/>

            </StackPanel>

        </Grid>
    </ScrollViewer>
    </DockPanel>
</UserControl>
