<UserControl
    x:Class="XSharp.Project.PropertyComboBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    x:Name="root">

    <!--
        PropertyComboBox — composite control: Label + ComboBox + Reset button.

        DataContext is NOT set here — inherits the page ViewModel so that
        Button.Command binds to ResetCommand and Button.IsEnabled binds to [PropertyName].

        Dependency properties (set by the page):
          Label        — text shown above the ComboBox
          Items        — ItemsSource for the ComboBox (IEnumerable)
          Value        — selected item (TwoWay)
          PropertyName — drives CommandParameter and IsEnabled indexer binding
          LabelMargin  — margin on the Label TextBlock (default 0,6,0,2)
    -->

    <StackPanel>
        <TextBlock x:Name="labelBlock"
                   Text="{Binding Label, ElementName=root}"
                   Margin="{Binding LabelMargin, ElementName=root}"
                   Style="{DynamicResource ThemedTextBlockStyle}"/>
        <StackPanel Orientation="Horizontal">
            <ComboBox x:Name="comboBox"
                      ItemsSource="{Binding Items, ElementName=root}"
                      SelectedItem="{Binding Value, ElementName=root, Mode=TwoWay}"
                      MinWidth="200"/>
            <Button x:Name="resetButton"
                Style="{DynamicResource ResetButtonStyle}"
                Command="{Binding ResetCommand}">
            </Button>

        </StackPanel>
    </StackPanel>

</UserControl>
