<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="..\Runtime.Sdk.Targets" />
  <PropertyGroup>
    <RootNamespace>XSharp</RootNamespace>
    <AssemblyName>XSharp.RDD</AssemblyName>
    <Dialect>Core</Dialect>
    <AZ>true</AZ>
    <INS>true</INS>
    <NamedArgs>True</NamedArgs>
    <Unsafe>True</Unsafe>
    <allowdot>true</allowdot>
    <EnforceSelf>True</EnforceSelf>
    <TargetFramework>net8.0</TargetFramework>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\XSharp.Core\XSharp.Core.Next.xsproj" />
  </ItemGroup>
</Project>