<UserControl
    x:Class="XSharp.Project.XPackagePropertyPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:XSharp.Project"
    xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
    xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
    mc:Ignorable="d" d:DesignWidth="660"
    UseLayoutRounding="True"
    FontFamily="{DynamicResource {x:Static vsshell:VsFonts.EnvironmentFontFamilyKey}}"
    FontSize="{DynamicResource {x:Static vsshell:VsFonts.EnvironmentFontSizeKey}}"
    toolkit:Themes.UseVsTheme="True"
    Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}" Height="809">

    <!--
        Package property page ├втВмтАЭ WPF/XAML implementation (SDK-style projects only).
        DataContext: XPackagePropertyPageViewModel (set by XPackagePropertyPageXamlHost).

        Two sections:
          Assembly Information ├втВмтАЭ Title, Description, Company, Copyright, NeutralLanguage
          NuGet Package        ├втВмтАЭ PackageId, PackageVersion, Authors, PackageTags,
                                 PackageLicenseExpression, PackageProjectUrl,
                                 RepositoryUrl, RepositoryType,
                                 GeneratePackageOnBuild, IsPackable
    -->

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/XSharp.AppDesigner2022;component/VsThemeDictionary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <local:BoolToVisibilityConverter x:Key="BoolToVisibility"        Invert="False"/>
            <local:BoolToVisibilityConverter x:Key="BoolToInverseVisibility" Invert="True"/>
            <local:PropertyOverriddenConverter x:Key="PropertyOverridden"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8"
                    Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}">

            <!-- ├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р -->
            <!-- Assembly Information                                    -->
            <!-- ├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р -->
            <Label Content="Assembly Information" FontWeight="SemiBold" Margin="0,4,0,2"/>
            <Separator Margin="0,0,0,4"/>

            <local:PropertyTextBox
                    Label="Title:"
                    Value="{Binding AssemblyTitle, Mode=TwoWay}"
                    PropertyName="AssemblyTitle"
                    ToolTip="AssemblyTitle тАФ human-readable name for the assembly."
                    LabelMargin="0,4,0,2"/>

            <Label Content="Description:" Margin="0,4,0,0"
                   ToolTip="Description ├втВмтАЭ used as both the assembly description and the NuGet package description when PackageDescription is not set."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         ToolTip="Description ├втВмтАЭ used as both the assembly description and the NuGet package description when PackageDescription is not set."/>
                <Button Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="Description"
                        Margin="4,0,0,0" VerticalAlignment="Top"/>
            </Grid>

            <local:PropertyTextBox
                    Label="Company:"
                    Value="{Binding Company, Mode=TwoWay}"
                    PropertyName="Company"
                    ToolTip="Company тАФ maps to [AssemblyCompany]."
                    LabelMargin="0,4,0,2"/>

            <local:PropertyTextBox
                    Label="Copyright:"
                    Value="{Binding Copyright, Mode=TwoWay}"
                    PropertyName="Copyright"
                    ToolTip="Copyright тАФ maps to [AssemblyCopyright] and the NuGet Copyright field."
                    LabelMargin="0,4,0,2"/>

            <local:PropertyTextBox
                    Label="Neutral Language:"
                    Value="{Binding NeutralLanguage, Mode=TwoWay}"
                    PropertyName="NeutralLanguage"
                    ToolTip="NeutralLanguage тАФ the culture of the assembly's neutral resources, e.g. en-US."
                    LabelMargin="0,4,0,2"/>

            <Label Content="Copyright:" Margin="0,4,0,0"
                   ToolTip="Copyright ├втВмтАЭ maps to [AssemblyCopyright] and the NuGet Copyright field."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding Copyright, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         ToolTip="Copyright ├втВмтАЭ maps to [AssemblyCopyright] and the NuGet Copyright field."/>
                <Button Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="Copyright"
                        Margin="4,0,0,0"/>
            </Grid>

            <Label Content="Neutral Language:" Margin="0,4,0,0"
                   ToolTip="NeutralLanguage ├втВмтАЭ the culture of the assembly's neutral resources, e.g. en-US."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding NeutralLanguage, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         ToolTip="NeutralLanguage ├втВмтАЭ the culture of the assembly's neutral resources, e.g. en-US."/>
                <Button Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="NeutralLanguage"
                        Margin="4,0,0,0"/>
            </Grid>

            <!-- ├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р -->
            <!-- NuGet Package                                           -->
            <!-- ├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р├втАв┬Р -->
            <Label Content="NuGet Package" FontWeight="SemiBold" Margin="0,16,0,2"/>
            <Separator Margin="0,0,0,4"/>

            <local:PropertyTextBox
                    Label="Package ID:"
                    Value="{Binding PackageId, Mode=TwoWay}"
                    PropertyName="PackageId"
                    ToolTip="PackageId тАФ the NuGet package identifier. Defaults to AssemblyName when not set."
                    LabelMargin="0,4,0,2"/>

            <local:PropertyTextBox
                    Label="Package Version:"
                    Value="{Binding PackageVersion, Mode=TwoWay}"
                    PropertyName="PackageVersion"
                    ToolTip="PackageVersion тАФ semver version string, e.g. 1.0.0 or 1.0.0-beta."
                    LabelMargin="0,4,0,2"/>

            <local:PropertyTextBox
                    Label="Authors:"
                    Value="{Binding Authors, Mode=TwoWay}"
                    PropertyName="Authors"
                    ToolTip="Authors тАФ semicolon-separated list of package authors."
                    LabelMargin="0,4,0,2"/>

            <local:PropertyTextBox
                    Label="Tags:"
                    Value="{Binding PackageTags, Mode=TwoWay}"
                    PropertyName="PackageTags"
                    ToolTip="PackageTags тАФ semicolon-delimited list of tags for the NuGet gallery."
                    LabelMargin="0,4,0,2"/>

            <local:PropertyTextBox
                    Label="License Expression (SPDX):"
                    Value="{Binding PackageLicenseExpression, Mode=TwoWay}"
                    PropertyName="PackageLicenseExpression"
                    ToolTip="PackageLicenseExpression тАФ an SPDX license identifier or expression, e.g. MIT or Apache-2.0."
                    LabelMargin="0,4,0,2"/>

            <local:PropertyTextBox
                    Label="Project URL:"
                    Value="{Binding PackageProjectUrl, Mode=TwoWay}"
                    PropertyName="PackageProjectUrl"
                    ToolTip="PackageProjectUrl тАФ URL to the project home page."
                    LabelMargin="0,4,0,2"/>

            <local:PropertyTextBox
                    Label="Repository URL:"
                    Value="{Binding RepositoryUrl, Mode=TwoWay}"
                    PropertyName="RepositoryUrl"
                    ToolTip="RepositoryUrl тАФ URL used to clone or retrieve source code."
                    LabelMargin="0,4,0,2"/>

            <local:PropertyTextBox
                    Label="Repository Type:"
                    Value="{Binding RepositoryType, Mode=TwoWay}"
                    PropertyName="RepositoryType"
                    ToolTip="RepositoryType тАФ type of the source repository, e.g. git or tfs."
                    LabelMargin="0,4,0,2"/>

            <Label Content="Package Version:" Margin="0,4,0,0"
                   ToolTip="PackageVersion ├втВмтАЭ semver version string, e.g. 1.0.0 or 1.0.0-beta."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding PackageVersion, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         ToolTip="PackageVersion ├втВмтАЭ semver version string, e.g. 1.0.0 or 1.0.0-beta."/>
                <Button Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="PackageVersion"
                        Margin="4,0,0,0"/>
            </Grid>

            <Label Content="Authors:" Margin="0,4,0,0"
                   ToolTip="Authors ├втВмтАЭ semicolon-separated list of package authors."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding Authors, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         ToolTip="Authors ├втВмтАЭ semicolon-separated list of package authors."/>
                <Button Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="Authors"
                        Margin="4,0,0,0"/>
            </Grid>

            <Label Content="Tags:" Margin="0,4,0,0"
                   ToolTip="PackageTags ├втВмтАЭ semicolon-delimited list of tags for the NuGet gallery."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding PackageTags, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         ToolTip="PackageTags ├втВмтАЭ semicolon-delimited list of tags for the NuGet gallery."/>
                <Button Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="PackageTags"
                        Margin="4,0,0,0"/>
            </Grid>

            <Label Content="License Expression (SPDX):" Margin="0,4,0,0"
                   ToolTip="PackageLicenseExpression ├втВмтАЭ an SPDX license identifier or expression, e.g. MIT or Apache-2.0."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding PackageLicenseExpression, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         ToolTip="PackageLicenseExpression ├втВмтАЭ an SPDX license identifier or expression, e.g. MIT or Apache-2.0."/>
                <Button Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="PackageLicenseExpression"
                        Margin="4,0,0,0"/>
            </Grid>

            <Label Content="Project URL:" Margin="0,4,0,0"
                   ToolTip="PackageProjectUrl ├втВмтАЭ URL to the project home page."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding PackageProjectUrl, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         ToolTip="PackageProjectUrl ├втВмтАЭ URL to the project home page."/>
                <Button Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="PackageProjectUrl"
                        Margin="4,0,0,0"/>
            </Grid>

            <Label Content="Repository URL:" Margin="0,4,0,0"
                   ToolTip="RepositoryUrl ├втВмтАЭ URL used to clone or retrieve source code."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding RepositoryUrl, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         ToolTip="RepositoryUrl ├втВмтАЭ URL used to clone or retrieve source code."/>
                <Button Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="RepositoryUrl"
                        Margin="4,0,0,0"/>
            </Grid>

            <Label Content="Repository Type:" Margin="0,4,0,0"
                   ToolTip="RepositoryType ├втВмтАЭ type of the source repository, e.g. git or tfs."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding RepositoryType, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         ToolTip="RepositoryType ├втВмтАЭ type of the source repository, e.g. git or tfs."/>
                <Button Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="RepositoryType"
                        Margin="4,0,0,0"/>
            </Grid>

            <local:PropertyCheckBox
                    Label="Generate NuGet package on build"
                    Value="{Binding GeneratePackageOnBuild, Mode=TwoWay}"
                    PropertyName="GeneratePackageOnBuild"
                    ToolTip="GeneratePackageOnBuild тАФ automatically creates a .nupkg file whenever the project is built."
                    Margin="0,8,0,0"/>

            <local:PropertyCheckBox
                    Label="Package this project"
                    Value="{Binding IsPackable, Mode=TwoWay}"
                    PropertyName="IsPackable"
                    ToolTip="IsPackable тАФ when unchecked, msbuild -t:pack will not produce a package for this project."
                    Margin="0,6,0,0"/>

            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                <CheckBox Content="Package this project"
                          IsChecked="{Binding IsPackable, Mode=TwoWay}"
                          ToolTip="IsPackable ├втВмтАЭ when unchecked, msbuild -t:pack will not produce a package for this project."
                          VerticalAlignment="Center"/>
                <Button Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="IsPackable"
                        Margin="4,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
