<?xml version="1.0" encoding="utf-8"?>
<!-- Specific targets for Framework type projects-->
<Project>
  <Import Project="VOSDK.Common.Props" />
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Debug|AnyCPU'" >
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Release|AnyCPU'" >
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Documentation|AnyCPU'" >
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'DocChinese|AnyCPU'" >
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'DocSpanish|AnyCPU'" >
  </PropertyGroup>
  <PropertyGroup>
    <!-- Adjusted for X# 3: output to Net46 folder-->
    <OutputPath>$(OutputPath)\net46\</OutputPath>
  </PropertyGroup>
  <PropertyGroup Condition="$(Configuration.Contains('Doc'))">
    <DocumentationFile>$(MSBuildProjectName).Xml</DocumentationFile>
  </PropertyGroup>
</Project>