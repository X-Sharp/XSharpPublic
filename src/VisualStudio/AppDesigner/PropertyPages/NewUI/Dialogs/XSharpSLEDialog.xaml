<Window
    x:Class="XSharp.Project.XSharpSLEDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:XSharp.Project"
    mc:Ignorable="d"
    Title="Property Value"
    Width="580" Height="360"
    MinWidth="400" MinHeight="280"
    WindowStartupLocation="CenterOwner"
    ShowInTaskbar="False"
    ResizeMode="CanResizeWithGrip"
    UseLayoutRounding="True"
    toolkit:Themes.UseVsTheme="True"
    xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit">

    <!--
        WPF replacement for XSharpSLEPropertyForm (Single Line Editor).
        Used by SDK-style property pages that need a single-line string editor
        with optional macro insertion, file browse, and folder browse.

        DataContext: XSharpMacroDialogViewModel (set in code-behind constructor).

        Layout:
          Row 0 — single-line TextBox (the property value)
          Row 1 — Insert File / Insert Folder buttons
          Row 2 — "Macros:" label
          Row 3 — macro DataGrid (fills remaining space)
          Row 4 — Insert Macro button + OK / Cancel
    -->

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/XSharp.AppDesigner2022;component/VsThemeDictionary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <local:BoolNegationConverter x:Key="BoolNegation"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: value TextBox -->
        <TextBox Grid.Row="0"
                 x:Name="tbValue"
                 Margin="0,0,0,4"
                 VerticalContentAlignment="Center"/>

        <!-- Row 1: file / folder browse buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Insert File…"   MinWidth="90" Margin="0,0,6,0" Click="OnInsertFileClick"
                    Visibility="{Binding HasFileBrowse, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Button Content="Insert Folder…" MinWidth="90"                   Click="OnInsertFolderClick"
                    Visibility="{Binding HasFileBrowse, RelativeSource={RelativeSource AncestorType=Window}}"/>
        </StackPanel>

        <!-- Row 2: Macros label -->
        <Label Grid.Row="2" Content="Macros:" Padding="0,0,0,2"/>

        <!-- Row 3: macro list -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Macros}"
                  SelectedItem="{Binding SelectedMacro, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  Margin="0,0,0,6"
                  MouseDoubleClick="OnMacroDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Macro" Binding="{Binding DisplayName}" Width="160"/>
                <DataGridTextColumn Header="Value" Binding="{Binding Value}"       Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Row 4: Insert Macro + OK / Cancel -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Content="Insert Macro"
                    MinWidth="100"
                    IsEnabled="{Binding CanInsertMacro}"
                    Click="OnInsertMacroClick"/>
            <Button Grid.Column="2"
                    Content="OK"
                    MinWidth="75"
                    IsDefault="True"
                    Click="OnOkClick"/>
            <Button Grid.Column="4"
                    Content="Cancel"
                    MinWidth="75"
                    IsCancel="True"/>
        </Grid>
    </Grid>
</Window>
