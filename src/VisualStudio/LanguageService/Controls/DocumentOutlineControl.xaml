<UserControl x:Class="XSharp.LanguageService.DocumentOutlineControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
             toolkit:Themes.UseVsTheme="True"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="300">
    <Grid>
        <Grid.Resources>
            <ResourceDictionary Source="VsThemeDictionary.xaml"/>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar row -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Height="28">
            <Button x:Name="_btnSortByName"
                    Content="#&#x2193;"
                    Width="32" Height="24"
                    Margin="2,2,2,2"
                    Padding="2"
                    ToolTip="Toggle sort: document order / alphabetical"
                    Click="OnSortToggle"/>
            <Button x:Name="_btnCollapseAll"
                    Content="-"
                    Width="32" Height="24"
                    Margin="0,2,2,2"
                    Padding="2"
                    ToolTip="Collapse all"
                    Click="OnCollapseAll"/>
            <Button x:Name="_btnExpandAll"
                    Content="+"
                    Width="32" Height="24"
                    Margin="0,2,2,2"
                    Padding="2"
                    ToolTip="Expand all"
                    Click="OnExpandAll"/>
        </StackPanel>

        <!-- Tree view -->
        <TreeView x:Name="_treeView"
                  Grid.Row="1"
                  SelectedItemChanged="OnNodeSelected"/>
    </Grid>
</UserControl>
