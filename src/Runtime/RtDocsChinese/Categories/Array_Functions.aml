          <row>
            <entry>
              <para>XSharp.RT</para>
            </entry>
            <entry>
              <para>
                <codeEntityReference qualifyHint="false" autoUpgrade="true">M:XSharp.RT.Functions.ASortEx(XSharp.__Array,XSharp.__Usual,XSharp.__Usual,XSharp.Codeblock)</codeEntityReference>
