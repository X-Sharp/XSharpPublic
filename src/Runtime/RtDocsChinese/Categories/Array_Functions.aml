            </entry>
            <entry>
              <para>
                <codeEntityReference qualifyHint="false" autoUpgrade="true">M:XSharp.VFP.Functions.ALen(XSharp.__FoxArray)</codeEntityReference>
              </para>
            </entry>
            <entry>
              <para>
