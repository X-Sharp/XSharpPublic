<Window
    x:Class="XSharp.Project.XSharpBuildEventEditorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:XSharp.Project"
    mc:Ignorable="d"
    Title="Build Event Command Line"
    Width="640" Height="460"
    MinWidth="480" MinHeight="360"
    WindowStartupLocation="CenterOwner"
    ShowInTaskbar="False"
    ResizeMode="CanResizeWithGrip"
    UseLayoutRounding="True"
    toolkit:Themes.UseVsTheme="True"
    xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit">

    <!--
        WPF replacement for XBuildEventEditorForm (Build Event Command Line editor).
        Used by the Build Events SDK-style property page.

        DataContext: XSharpMacroDialogViewModel (set in code-behind constructor).

        Layout:
          Row 0 — "Command line:" label
          Row 1 — multi-line command TextBox (fills top half)
          Row 2 — "Macros:" label
          Row 3 — macro DataGrid (fills remaining space)
          Row 4 — Insert Macro button + OK / Cancel
    -->

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/XSharp.AppDesigner2022;component/VsThemeDictionary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: label -->
        <Label Grid.Row="0" Content="Command line:" Padding="0,0,0,2"/>

        <!-- Row 1: command TextBox -->
        <TextBox Grid.Row="1"
                 x:Name="tbCommand"
                 Margin="0,0,0,8"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"
                 FontFamily="Consolas"
                 FontSize="12"/>

        <!-- Row 2: Macros label -->
        <Label Grid.Row="2" Content="Macros:" Padding="0,0,0,2"/>

        <!-- Row 3: macro list -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Macros}"
                  SelectedItem="{Binding SelectedMacro, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  Margin="0,0,0,6"
                  MouseDoubleClick="OnMacroDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Macro" Binding="{Binding DisplayName}" Width="160"/>
                <DataGridTextColumn Header="Value" Binding="{Binding Value}"       Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Row 4: Insert Macro + OK / Cancel -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Content="Insert Macro"
                    MinWidth="100"
                    IsEnabled="{Binding CanInsertMacro}"
                    Click="OnInsertMacroClick"/>
            <Button Grid.Column="2"
                    Content="OK"
                    MinWidth="75"
                    IsDefault="True"
                    Click="OnOkClick"/>
            <Button Grid.Column="4"
                    Content="Cancel"
                    MinWidth="75"
                    IsCancel="True"/>
        </Grid>
    </Grid>
</Window>
