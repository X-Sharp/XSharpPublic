<Window x:Class="XSharp.LanguageService.GotoDefinitionResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
        toolkit:Themes.UseVsTheme="True"
        Title="X# Goto Definition Results"
        Width="600" Height="300"
        MinWidth="350" MinHeight="150"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        WindowStartupLocation="Manual">
    <Grid>
        <Grid.Resources>
            <ResourceDictionary Source="VsThemeDictionary.xaml"/>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListView x:Name="_listView"
                  Grid.Row="0"
                  MouseDoubleClick="OnItemDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Name" Width="200"
                                    DisplayMemberBinding="{Binding DisplayName}"/>
                    <GridViewColumn Header="Location" Width="380"
                                    DisplayMemberBinding="{Binding Location}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <TextBlock Grid.Row="1"
                   Margin="4,2,4,4"
                   FontStyle="Italic"
                   Text="Double-click an item or press Enter to navigate. Press Escape to close."/>
    </Grid>
</Window>
