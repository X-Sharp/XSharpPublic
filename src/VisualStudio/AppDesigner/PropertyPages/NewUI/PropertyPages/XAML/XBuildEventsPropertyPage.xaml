<UserControl
    x:Class="XSharp.Project.XBuildEventsPropertyPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:XSharp.Project"
    mc:Ignorable="d"
    d:DesignHeight="420" d:DesignWidth="660"
    UseLayoutRounding="True"
    toolkit:Themes.UseVsTheme="True"
    xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
    xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
    FontFamily="{DynamicResource {x:Static vsshell:VsFonts.EnvironmentFontFamilyKey}}"
    FontSize="{DynamicResource {x:Static vsshell:VsFonts.EnvironmentFontSizeKey}}">

    <!--
        Build Events property page - WPF/XAML implementation (SDK-style projects).
        DataContext: XBuildEventsPropertyPageViewModel (set by XBuildEventsPropertyPageXamlHost).

        Layout mirrors the WinForms XBuildEventsPropertyPagePanel:
          Group 1 - Pre-build Event Command Line  (multiline TextBox + "Edit Pre-build..." button)
          Group 2 - Post-build Event Command Line (multiline TextBox + "Edit Post-build..." button)
                    Run the post-build event:     (ComboBox)
    -->

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/XSharp.AppDesigner2022;component/VsThemeDictionary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel>

        <!-- Configuration selector - hidden until per-config Build Events is implemented.
        <DockPanel DockPanel.Dock="Top" Margin="8,8,8,4" LastChildFill="False">
            <Label DockPanel.Dock="Left" Content="Configuration:" VerticalAlignment="Center" Padding="0,0,4,0"/>
            <ComboBox DockPanel.Dock="Left"
                      ItemsSource="{Binding ConfigSelector.ConfigNames}"
                      SelectedItem="{Binding ConfigSelector.SelectedConfig, Mode=TwoWay}"
                      Width="200" VerticalAlignment="Center"/>
        </DockPanel>
        -->

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="8">

            <!-- ==================== Pre-build group ==================== -->
            <GroupBox Header="{Binding CaptPreBuildEvent}" Margin="0,0,0,8">
                <StackPanel Margin="4">
                    <TextBox Text="{Binding PreBuildEvent, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                             AcceptsReturn="True"
                             Height="90"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             Margin="0,0,0,4"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Style="{DynamicResource ResetButtonStyle}"
                                Command="{Binding ResetCommand}" CommandParameter="PreBuildEvent"
                                Margin="4,0,0,0"/>
                        <Button Content="{Binding CaptEditPreBuild}"
                                HorizontalAlignment="Right"
                                MinWidth="120"
                                Click="OnEditPreBuildClick"/>
                    </DockPanel>
                </StackPanel>
            </GroupBox>

            <!-- ==================== Post-build group ==================== -->
            <GroupBox Header="{Binding CaptPostBuildEvent}" Margin="0,0,0,8">
                <StackPanel Margin="4">
                    <TextBox Text="{Binding PostBuildEvent, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                             AcceptsReturn="True"
                             Height="90"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             Margin="0,0,0,4"/>
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right"
                                Style="{DynamicResource ResetButtonStyle}"
                                Command="{Binding ResetCommand}" CommandParameter="PostBuildEvent"
                                Margin="4,0,0,0"/>
                        <Button Content="{Binding CaptEditPostBuild}"
                                HorizontalAlignment="Right"
                                MinWidth="120"
                                Click="OnEditPostBuildClick"/>
                    </DockPanel>

                    <!-- Run post-build combo -->
                    <local:PropertyComboBox
                            Label="{Binding CaptRunPostBuildEvent}"
                            Items="{Binding RunPostBuildEventValues}"
                            Value="{Binding RunPostBuildEvent, Mode=TwoWay}"
                            PropertyName="RunPostBuildEvent"
                            LabelMargin="0,0,0,2"
                            Margin="0,0,0,0"/>
                </StackPanel>
            </GroupBox>

        </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
