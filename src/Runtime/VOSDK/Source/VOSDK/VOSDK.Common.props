<?xml version="1.0" encoding="utf-8"?>
<Project>
  <Import Project="..\..\..\..\Shared.Props" />
  <PropertyGroup>
    <MSBuildAllProjects>$(MSBuildAllProjects);$(MSBuildThisFileFullPath)</MSBuildAllProjects>
    <OutputType>Library</OutputType>
    <RootNamespace>VO</RootNamespace>
    <TargetFrameworkVersion>v4.6</TargetFrameworkVersion>
    <TargetFrameworkProfile />
    <Nostandarddefs>true</Nostandarddefs>
    <SignAssembly>true</SignAssembly>
    <DelaySign>false</DelaySign>
    <Prefer32Bit>False</Prefer32Bit>
    <CommandLineOption />
    <Unsafe>true</Unsafe>
    <INS>true</INS>
    <NS>true</NS>
    <VO2>true</VO2>
    <VO3>true</VO3>
    <VO4>true</VO4>
    <VO5>true</VO5>
    <VO6>true</VO6>
    <VO7>true</VO7>
    <VO8>true</VO8>
    <VO9>true</VO9>
    <VO10>true</VO10>
    <VO11>true</VO11>
    <VO14>true</VO14>
    <vo15>true</vo15>
    <IncludePaths>$(CommonDir)</IncludePaths>
    <ErrorReport>prompt</ErrorReport>
    <Dialect>Vulcan</Dialect>
    <StartupObject />
    <ApplicationIcon />
    <VulcanCompatibleResources>True</VulcanCompatibleResources>
    <PlatformTarget>x86</PlatformTarget>
    <WarningLevel>4</WarningLevel>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
  </PropertyGroup>
  <PropertyGroup Condition="$(Configuration.Contains('Doc'))">
    <DocumentationFile>$(MSBuildProjectName).Xml</DocumentationFile>
    <EmitDebugInformation>true</EmitDebugInformation>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <DefineConstants>DEBUG;TRACE;DOCUMENTATION;RUNTIME</DefineConstants>
    <NoWarn>$(DisabledWarnings);$(NoWarn);165,169,9032,170,618,9068,108,9043,169,9015,649,414,1591,1573</NoWarn>
    <CommandLineOption>/noclipcall </CommandLineOption>
	<vo15>true</vo15>
	<vo5>false</vo5>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Release'" >
    <EmitDebugInformation>false</EmitDebugInformation>
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <DefineConstants>TRACE;RUNTIME</DefineConstants>
    <NoWarn>$(DisabledWarnings);$(NoWarn);165,9032,170,618,9068,108,9043</NoWarn>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'" >
    <EmitDebugInformation>true</EmitDebugInformation>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <DefineConstants>DEBUG;TRACE;RUNTIME</DefineConstants>
    <NoWarn>$(DisabledWarnings);$(NoWarn);165,9032,170,618,9068,108,9043</NoWarn>
  </PropertyGroup>

</Project>