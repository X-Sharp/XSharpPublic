<UserControl
    x:Class="XSharp.Project.XGeneralPropertyPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:XSharp.Project"
    xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
    xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
    mc:Ignorable="d"
    d:DesignHeight="400" d:DesignWidth="660"
    UseLayoutRounding="True"
    FontFamily="{DynamicResource {x:Static vsshell:VsFonts.EnvironmentFontFamilyKey}}"
    FontSize="{DynamicResource {x:Static vsshell:VsFonts.EnvironmentFontSizeKey}}"
    toolkit:Themes.UseVsTheme="True" >

    <!--
        General (Application) property page — WPF/XAML implementation (SDK-style projects).
        DataContext: XGeneralPropertyPageViewModel (set by XGeneralPropertyPageXamlHost).

        Layout mirrors the WinForms XGeneralPropertyPagePanel (two-column table):
          Left column  — Application name, Target Framework, Dialect,
                         Auto-generate binding redirects, Resources header,
                         Icon, Suppress manifest, Prefer native, Vulcan resources.
          Right column — Default namespace, Output type, Startup object.
    -->

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/XSharp.AppDesigner2022;component/VsThemeDictionary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <!-- BoolToVisibility: true → Visible, false → Collapsed -->
            <local:BoolToVisibilityConverter x:Key="BoolToVisibility"        Invert="False"/>
            <!-- BoolToInverseVisibility: true → Collapsed, false → Visible -->
            <local:BoolToVisibilityConverter x:Key="BoolToInverseVisibility" Invert="True"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="8,8,8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 0 label row -->
                <RowDefinition Height="Auto"/>  <!-- 1 input row -->
                <RowDefinition Height="Auto"/>  <!-- 2 label -->
                <RowDefinition Height="Auto"/>  <!-- 3 input (framework) -->
                <RowDefinition Height="Auto"/>  <!-- 4 label -->
                <RowDefinition Height="Auto"/>  <!-- 5 input (dialect) -->
                <RowDefinition Height="Auto"/>  <!-- 6 checkbox -->
                <RowDefinition Height="Auto"/>  <!-- 7 section header -->
                <RowDefinition Height="Auto"/>  <!-- 8 icon label -->
                <RowDefinition Height="Auto"/>  <!-- 9 icon input -->
                <RowDefinition Height="Auto"/>  <!-- 10 checkbox -->
                <RowDefinition Height="Auto"/>  <!-- 11 checkbox -->
                <RowDefinition Height="Auto"/>  <!-- 12 checkbox -->
            </Grid.RowDefinitions>

            <!-- ============================================================ -->
            <!-- LEFT COLUMN                                                   -->
            <!-- ============================================================ -->

            <!-- Row 0/1: Application Name -->
            <Label  Grid.Column="0" Grid.Row="0" Content="{Binding CaptAppName}"
                    Margin="0,4,8,0" VerticalAlignment="Center"/>
            <Grid   Grid.Column="0" Grid.Row="1" Margin="0,2,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding AssemblyName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         ToolTip="{Binding DescAssembly}"/>
                 <Button  Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                         Command="{Binding ResetCommand}" CommandParameter="AssemblyName"
                         IsEnabled="{Binding [AssemblyName]}"
                         Margin="4,0,0,0"/>
            </Grid>

            <!-- Row 2/3: Target Framework (combo for single, textbox for multi) -->
            <Label  Grid.Column="0" Grid.Row="2"
                    Content="{Binding TargetFrameworkLabel}"
                    Margin="0,6,8,0" VerticalAlignment="Center"/>
            <!-- Single-target combo + reset -->
            <Grid   Grid.Column="0" Grid.Row="3" Margin="0,2,8,0"
                    Visibility="{Binding IsMultiTargeting, Converter={StaticResource BoolToInverseVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding FrameworkItems}"
                          SelectedItem="{Binding TargetFramework, Mode=TwoWay}"/>
                 <Button   Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                           Command="{Binding ResetCommand}" CommandParameter="TargetFramework"
                           IsEnabled="{Binding [TargetFramework]}"
                           Margin="4,0,0,0"/>
            </Grid>
            <!-- Multi-target textbox + reset -->
            <Grid   Grid.Column="0" Grid.Row="3" Margin="0,2,8,0"
                    Visibility="{Binding IsMultiTargeting, Converter={StaticResource BoolToVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding TargetFrameworks, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                 <Button  Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                          Command="{Binding ResetCommand}" CommandParameter="TargetFrameworks"
                          IsEnabled="{Binding [TargetFrameworks]}"
                          Margin="4,0,0,0"/>
            </Grid>

            <!-- Row 4/5: Dialect -->
            <Label  Grid.Column="0" Grid.Row="4" Content="Dialect:"
                    ToolTip="{Binding DescDialect}"
                    Margin="0,6,8,0" VerticalAlignment="Center"/>
            <Grid   Grid.Column="0" Grid.Row="5" Margin="0,2,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding DialectItems}"
                          SelectedItem="{Binding Dialect, Mode=TwoWay}"
                          ToolTip="{Binding DescDialect}"/>
                 <Button   Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                           Command="{Binding ResetCommand}" CommandParameter="Dialect"
                           IsEnabled="{Binding [Dialect]}"
                           Margin="4,0,0,0"/>
            </Grid>

            <!-- Row 6: Auto-generate binding redirects -->
            <local:PropertyCheckBox Grid.Column="0" Grid.Row="6"
                    Label="{Binding CaptBindingRedirects}"
                    Value="{Binding AutoGenerateBindingRedirects, Mode=TwoWay}"
                    PropertyName="AutoGenerateBindingRedirects"
                    ToolTip="{Binding DescBindingRedirects}"
                    Margin="0,8,8,0"/>

            <!-- Row 7: Resources section header -->
            <Label  Grid.Column="0" Grid.Row="7" Content="Resources:"
                    FontWeight="Bold" Margin="0,10,8,0" VerticalAlignment="Center"/>

            <!-- Row 8: Icon label -->
            <Label  Grid.Column="0" Grid.Row="8" Content="{Binding CaptIcon}"
                    IsEnabled="{Binding IconEnabled}"
                    ToolTip="{Binding DescIcon}"
                    Margin="0,4,8,0" VerticalAlignment="Center"/>

            <!-- Row 9: Icon textbox + browse button + reset button -->
            <Grid   Grid.Column="0" Grid.Row="9" Margin="0,2,8,0"
                    IsEnabled="{Binding IconEnabled}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding ApplicationIcon, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         ToolTip="{Binding DescIcon}"/>
                <Button  Grid.Column="1" Content="..." Width="26" Margin="4,0,0,0"
                         ToolTip="{Binding DescIcon}"
                         Click="OnBrowseIconClick"/>
                 <Button  Grid.Column="2" Style="{DynamicResource ResetButtonStyle}"
                          Command="{Binding ResetCommand}" CommandParameter="ApplicationIcon"
                          IsEnabled="{Binding [ApplicationIcon]}"
                          Margin="4,0,0,0"/>
            </Grid>

            <!-- Row 10: Suppress default Win32 manifest -->
            <StackPanel Grid.Column="0" Grid.Row="10" Orientation="Horizontal" Margin="0,8,8,0">
                <CheckBox Content="{Binding CaptWin32Manifest}"
                          IsChecked="{Binding SuppressDefaultManifest, Mode=TwoWay}"
                          ToolTip="{Binding DescWin32Manifest}"
                          VerticalAlignment="Center"/>
                <Button Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="NoWin32Manifest"
                        IsEnabled="{Binding [NoWin32Manifest]}"
                        Margin="4,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Row 11: Prefer native version -->
            <StackPanel Grid.Column="0" Grid.Row="11" Orientation="Horizontal" Margin="0,6,8,0">
                <CheckBox Content="{Binding CaptPreferNative}"
                          IsChecked="{Binding PreferNativeVersion, Mode=TwoWay}"
                          ToolTip="{Binding DescPreferNative}"
                          VerticalAlignment="Center"/>
                <Button Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="UseNativeVersion"
                        IsEnabled="{Binding [UseNativeVersion]}"
                        Margin="4,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Row 12: Vulcan compatible managed resources -->
            <StackPanel Grid.Column="0" Grid.Row="12" Orientation="Horizontal" Margin="0,6,8,0">
                <CheckBox Content="{Binding CaptVulcanCompatibleResources}"
                          IsChecked="{Binding VulcanCompatibleResources, Mode=TwoWay}"
                          ToolTip="{Binding DescVulcanCompatibleResources}"
                          VerticalAlignment="Center"/>
                <Button Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="VulcanCompatibleResources"
                        IsEnabled="{Binding [VulcanCompatibleResources]}"
                        Margin="4,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- ============================================================ -->
            <!-- RIGHT COLUMN                                                  -->
            <!-- ============================================================ -->

            <!-- Row 0/1: Default Namespace -->
            <Label  Grid.Column="1" Grid.Row="0" Content="{Binding CaptNamespace}"
                    ToolTip="{Binding DescNamespace}"
                    Margin="8,4,0,0" VerticalAlignment="Center"/>
            <Grid   Grid.Column="1" Grid.Row="1" Margin="8,2,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding RootNamespace, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         ToolTip="{Binding DescNamespace}"/>
                 <Button  Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                          Command="{Binding ResetCommand}" CommandParameter="RootNamespace"
                          IsEnabled="{Binding [RootNamespace]}"
                          Margin="4,0,0,0"/>
            </Grid>

            <!-- Row 2/3: Output Type -->
            <Label  Grid.Column="1" Grid.Row="2" Content="Output Type:"
                    ToolTip="{Binding DescOutputType}"
                    Margin="8,6,0,0" VerticalAlignment="Center"/>
            <Grid   Grid.Column="1" Grid.Row="3" Margin="8,2,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding OutputTypeItems}"
                          SelectedItem="{Binding OutputType, Mode=TwoWay}"
                          ToolTip="{Binding DescOutputType}"/>
                 <Button   Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                           Command="{Binding ResetCommand}" CommandParameter="OutputType"
                           IsEnabled="{Binding [OutputType]}"
                           Margin="4,0,0,0"/>
            </Grid>

            <!-- Row 4/5: Startup Object (aligned to Dialect rows on left) -->
            <Label  Grid.Column="1" Grid.Row="4" Content="{Binding CaptStartup}"
                    ToolTip="{Binding DescStartup}"
                    Margin="8,6,0,0" VerticalAlignment="Center"/>
            <Grid   Grid.Column="1" Grid.Row="5" Margin="8,2,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding StartupItems}"
                          SelectedItem="{Binding StartupObject, Mode=TwoWay}"
                          IsEnabled="{Binding StartupObjectEnabled}"
                          ToolTip="{Binding DescStartup}"/>
                 <Button   Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                           Command="{Binding ResetCommand}" CommandParameter="StartupObject"
                           IsEnabled="{Binding [StartupObject]}"
                           Margin="4,0,0,0"/>
            </Grid>

        </Grid>
    </ScrollViewer>
</UserControl>
