<UserControl
    x:Class="XSharp.Project.XPackagePropertyPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:XSharp.Project"
    xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
    xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
    mc:Ignorable="d"
    d:DesignHeight="600" d:DesignWidth="660"
    UseLayoutRounding="True"
    toolkit:Themes.UseVsTheme="True"
    Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}">

    <!--
        Package property page — WPF/XAML implementation (SDK-style projects only).
        DataContext: XPackagePropertyPageViewModel (set by XPackagePropertyPageXamlHost).

        Two sections:
          Assembly Information — Title, Description, Company, Copyright, NeutralLanguage
          NuGet Package        — PackageId, PackageVersion, Authors, PackageTags,
                                 PackageLicenseExpression, PackageProjectUrl,
                                 RepositoryUrl, RepositoryType,
                                 GeneratePackageOnBuild, IsPackable
    -->

    <UserControl.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibility"        Invert="False"/>
        <local:BoolToVisibilityConverter x:Key="BoolToInverseVisibility" Invert="True"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8"
                    Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}">

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- Assembly Information                                    -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Label Content="Assembly Information" FontWeight="SemiBold" Margin="0,4,0,2"/>
            <Separator Margin="0,0,0,4"/>

            <Label Content="Title:"
                   ToolTip="AssemblyTitle — human-readable name for the assembly."/>
            <TextBox Text="{Binding AssemblyTitle, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                     ToolTip="AssemblyTitle — human-readable name for the assembly."/>

            <Label Content="Description:" Margin="0,4,0,0"
                   ToolTip="Description — used as both the assembly description and the NuGet package description when PackageDescription is not set."/>
            <TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                     Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                     ToolTip="Description — used as both the assembly description and the NuGet package description when PackageDescription is not set."/>

            <Label Content="Company:" Margin="0,4,0,0"
                   ToolTip="Company — maps to [AssemblyCompany]."/>
            <TextBox Text="{Binding Company, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                     ToolTip="Company — maps to [AssemblyCompany]."/>

            <Label Content="Copyright:" Margin="0,4,0,0"
                   ToolTip="Copyright — maps to [AssemblyCopyright] and the NuGet Copyright field."/>
            <TextBox Text="{Binding Copyright, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                     ToolTip="Copyright — maps to [AssemblyCopyright] and the NuGet Copyright field."/>

            <Label Content="Neutral Language:" Margin="0,4,0,0"
                   ToolTip="NeutralLanguage — the culture of the assembly's neutral resources, e.g. en-US."/>
            <TextBox Text="{Binding NeutralLanguage, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                     ToolTip="NeutralLanguage — the culture of the assembly's neutral resources, e.g. en-US."/>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- NuGet Package                                           -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Label Content="NuGet Package" FontWeight="SemiBold" Margin="0,16,0,2"/>
            <Separator Margin="0,0,0,4"/>

            <Label Content="Package ID:"
                   ToolTip="PackageId — the NuGet package identifier. Defaults to AssemblyName when not set."/>
            <TextBox Text="{Binding PackageId, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                     ToolTip="PackageId — the NuGet package identifier. Defaults to AssemblyName when not set."/>

            <Label Content="Package Version:" Margin="0,4,0,0"
                   ToolTip="PackageVersion — semver version string, e.g. 1.0.0 or 1.0.0-beta."/>
            <TextBox Text="{Binding PackageVersion, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                     ToolTip="PackageVersion — semver version string, e.g. 1.0.0 or 1.0.0-beta."/>

            <Label Content="Authors:" Margin="0,4,0,0"
                   ToolTip="Authors — semicolon-separated list of package authors."/>
            <TextBox Text="{Binding Authors, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                     ToolTip="Authors — semicolon-separated list of package authors."/>

            <Label Content="Tags:" Margin="0,4,0,0"
                   ToolTip="PackageTags — semicolon-delimited list of tags for the NuGet gallery."/>
            <TextBox Text="{Binding PackageTags, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                     ToolTip="PackageTags — semicolon-delimited list of tags for the NuGet gallery."/>

            <Label Content="License Expression (SPDX):" Margin="0,4,0,0"
                   ToolTip="PackageLicenseExpression — an SPDX license identifier or expression, e.g. MIT or Apache-2.0."/>
            <TextBox Text="{Binding PackageLicenseExpression, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                     ToolTip="PackageLicenseExpression — an SPDX license identifier or expression, e.g. MIT or Apache-2.0."/>

            <Label Content="Project URL:" Margin="0,4,0,0"
                   ToolTip="PackageProjectUrl — URL to the project home page."/>
            <TextBox Text="{Binding PackageProjectUrl, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                     ToolTip="PackageProjectUrl — URL to the project home page."/>

            <Label Content="Repository URL:" Margin="0,4,0,0"
                   ToolTip="RepositoryUrl — URL used to clone or retrieve source code."/>
            <TextBox Text="{Binding RepositoryUrl, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                     ToolTip="RepositoryUrl — URL used to clone or retrieve source code."/>

            <Label Content="Repository Type:" Margin="0,4,0,0"
                   ToolTip="RepositoryType — type of the source repository, e.g. git or tfs."/>
            <TextBox Text="{Binding RepositoryType, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                     ToolTip="RepositoryType — type of the source repository, e.g. git or tfs."/>

            <CheckBox Content="Generate NuGet package on build"
                      IsChecked="{Binding GeneratePackageOnBuild, Mode=TwoWay}"
                      Margin="0,8,0,0"
                      ToolTip="GeneratePackageOnBuild — automatically creates a .nupkg file whenever the project is built."/>

            <CheckBox Content="Package this project"
                      IsChecked="{Binding IsPackable, Mode=TwoWay}"
                      Margin="0,6,0,0"
                      ToolTip="IsPackable — when unchecked, msbuild -t:pack will not produce a package for this project."/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
