<UserControl
    x:Class="XSharp.Project.XPackagePropertyPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:XSharp.Project"
    xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
    xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
    mc:Ignorable="d" d:DesignWidth="660"
    UseLayoutRounding="True"
    FontFamily="{DynamicResource {x:Static vsshell:VsFonts.EnvironmentFontFamilyKey}}"
    FontSize="{DynamicResource {x:Static vsshell:VsFonts.EnvironmentFontSizeKey}}"
    toolkit:Themes.UseVsTheme="True"
    Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}" Height="809">

    <!--
        Package property page — WPF/XAML implementation (SDK-style projects only).
        DataContext: XPackagePropertyPageViewModel (set by XPackagePropertyPageXamlHost).

        Two sections:
          Assembly Information — Title, Description, Company, Copyright, NeutralLanguage
          NuGet Package        — PackageId, PackageVersion, Authors, PackageTags,
                                 PackageLicenseExpression, PackageProjectUrl,
                                 RepositoryUrl, RepositoryType,
                                 GeneratePackageOnBuild, IsPackable
    -->

    <UserControl.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibility"        Invert="False"/>
        <local:BoolToVisibilityConverter x:Key="BoolToInverseVisibility" Invert="True"/>
        <local:PropertyOverriddenConverter x:Key="PropertyOverridden"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8"
                    Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}">

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- Assembly Information                                    -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Label Content="Assembly Information" FontWeight="SemiBold" Margin="0,4,0,2"/>
            <Separator Margin="0,0,0,4"/>

            <Label Content="Title:"
                   ToolTip="AssemblyTitle — human-readable name for the assembly."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding AssemblyTitle, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         ToolTip="AssemblyTitle — human-readable name for the assembly."/>
                <Button Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="AssemblyTitle"
                        IsEnabled="{Binding [AssemblyTitle]}"
                        Margin="4,0,0,0"/>
            </Grid>

            <Label Content="Description:" Margin="0,4,0,0"
                   ToolTip="Description — used as both the assembly description and the NuGet package description when PackageDescription is not set."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         ToolTip="Description — used as both the assembly description and the NuGet package description when PackageDescription is not set."/>
                <Button Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="Description"
                        IsEnabled="{Binding [Description]}"
                        Margin="4,0,0,0" VerticalAlignment="Top"/>
            </Grid>

            <Label Content="Company:" Margin="0,4,0,0"
                   ToolTip="Company — maps to [AssemblyCompany]."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding Company, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         ToolTip="Company — maps to [AssemblyCompany]."/>
                <Button Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="Company"
                        IsEnabled="{Binding [Company]}"
                        Margin="4,0,0,0"/>
            </Grid>

            <Label Content="Copyright:" Margin="0,4,0,0"
                   ToolTip="Copyright — maps to [AssemblyCopyright] and the NuGet Copyright field."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding Copyright, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         ToolTip="Copyright — maps to [AssemblyCopyright] and the NuGet Copyright field."/>
                <Button Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="Copyright"
                        IsEnabled="{Binding [Copyright]}"
                        Margin="4,0,0,0"/>
            </Grid>

            <Label Content="Neutral Language:" Margin="0,4,0,0"
                   ToolTip="NeutralLanguage — the culture of the assembly's neutral resources, e.g. en-US."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding NeutralLanguage, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         ToolTip="NeutralLanguage — the culture of the assembly's neutral resources, e.g. en-US."/>
                <Button Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="NeutralLanguage"
                        IsEnabled="{Binding [NeutralLanguage]}"
                        Margin="4,0,0,0"/>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- NuGet Package                                           -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Label Content="NuGet Package" FontWeight="SemiBold" Margin="0,16,0,2"/>
            <Separator Margin="0,0,0,4"/>

            <Label Content="Package ID:"
                   ToolTip="PackageId — the NuGet package identifier. Defaults to AssemblyName when not set."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding PackageId, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         ToolTip="PackageId — the NuGet package identifier. Defaults to AssemblyName when not set."/>
                <Button Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="PackageId"
                        IsEnabled="{Binding [PackageId]}"
                        Margin="4,0,0,0"/>
            </Grid>

            <Label Content="Package Version:" Margin="0,4,0,0"
                   ToolTip="PackageVersion — semver version string, e.g. 1.0.0 or 1.0.0-beta."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding PackageVersion, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         ToolTip="PackageVersion — semver version string, e.g. 1.0.0 or 1.0.0-beta."/>
                <Button Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="PackageVersion"
                        IsEnabled="{Binding [PackageVersion]}"
                        Margin="4,0,0,0"/>
            </Grid>

            <Label Content="Authors:" Margin="0,4,0,0"
                   ToolTip="Authors — semicolon-separated list of package authors."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding Authors, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         ToolTip="Authors — semicolon-separated list of package authors."/>
                <Button Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="Authors"
                        IsEnabled="{Binding [Authors]}"
                        Margin="4,0,0,0"/>
            </Grid>

            <Label Content="Tags:" Margin="0,4,0,0"
                   ToolTip="PackageTags — semicolon-delimited list of tags for the NuGet gallery."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding PackageTags, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         ToolTip="PackageTags — semicolon-delimited list of tags for the NuGet gallery."/>
                <Button Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="PackageTags"
                        IsEnabled="{Binding [PackageTags]}"
                        Margin="4,0,0,0"/>
            </Grid>

            <Label Content="License Expression (SPDX):" Margin="0,4,0,0"
                   ToolTip="PackageLicenseExpression — an SPDX license identifier or expression, e.g. MIT or Apache-2.0."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding PackageLicenseExpression, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         ToolTip="PackageLicenseExpression — an SPDX license identifier or expression, e.g. MIT or Apache-2.0."/>
                <Button Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="PackageLicenseExpression"
                        IsEnabled="{Binding [PackageLicenseExpression]}"
                        Margin="4,0,0,0"/>
            </Grid>

            <Label Content="Project URL:" Margin="0,4,0,0"
                   ToolTip="PackageProjectUrl — URL to the project home page."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding PackageProjectUrl, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         ToolTip="PackageProjectUrl — URL to the project home page."/>
                <Button Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="PackageProjectUrl"
                        IsEnabled="{Binding [PackageProjectUrl]}"
                        Margin="4,0,0,0"/>
            </Grid>

            <Label Content="Repository URL:" Margin="0,4,0,0"
                   ToolTip="RepositoryUrl — URL used to clone or retrieve source code."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding RepositoryUrl, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         ToolTip="RepositoryUrl — URL used to clone or retrieve source code."/>
                <Button Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="RepositoryUrl"
                        IsEnabled="{Binding [RepositoryUrl]}"
                        Margin="4,0,0,0"/>
            </Grid>

            <Label Content="Repository Type:" Margin="0,4,0,0"
                   ToolTip="RepositoryType — type of the source repository, e.g. git or tfs."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding RepositoryType, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                         ToolTip="RepositoryType — type of the source repository, e.g. git or tfs."/>
                <Button Grid.Column="1" Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="RepositoryType"
                        IsEnabled="{Binding [RepositoryType]}"
                        Margin="4,0,0,0"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <CheckBox Content="Generate NuGet package on build"
                          IsChecked="{Binding GeneratePackageOnBuild, Mode=TwoWay}"
                          ToolTip="GeneratePackageOnBuild — automatically creates a .nupkg file whenever the project is built."
                          VerticalAlignment="Center"/>
                <Button Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="GeneratePackageOnBuild"
                        IsEnabled="{Binding [GeneratePackageOnBuild]}"
                        Margin="4,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                <CheckBox Content="Package this project"
                          IsChecked="{Binding IsPackable, Mode=TwoWay}"
                          ToolTip="IsPackable — when unchecked, msbuild -t:pack will not produce a package for this project."
                          VerticalAlignment="Center"/>
                <Button Style="{DynamicResource ResetButtonStyle}"
                        Command="{Binding ResetCommand}" CommandParameter="IsPackable"
                        IsEnabled="{Binding [IsPackable]}"
                        Margin="4,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
