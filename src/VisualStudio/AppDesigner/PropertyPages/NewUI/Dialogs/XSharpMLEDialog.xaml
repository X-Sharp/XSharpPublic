<Window
    x:Class="XSharp.Project.XSharpMLEDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:XSharp.Project"
    mc:Ignorable="d"
    Title="Property Value"
    Width="580" Height="420"
    MinWidth="400" MinHeight="320"
    WindowStartupLocation="CenterOwner"
    ShowInTaskbar="False"
    ResizeMode="CanResizeWithGrip"
    UseLayoutRounding="True"
    toolkit:Themes.UseVsTheme="True"
    xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit">

    <!--
        WPF replacement for XSharpMLEPropertyForm (Multi-Line Editor).
        Used by SDK-style property pages that need a multi-line string editor
        with optional macro insertion.

        DataContext: XSharpMacroDialogViewModel (set in code-behind constructor).

        Layout:
          Row 0 — multi-line TextBox (the property value, ~4 lines tall)
          Row 1 — "Macros:" label
          Row 2 — macro DataGrid (fills remaining space)
          Row 3 — Insert Macro button + OK / Cancel
    -->

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: multi-line value TextBox -->
        <TextBox Grid.Row="0"
                 x:Name="tbValue"
                 Margin="0,0,0,8"
                 MinLines="4"
                 MaxLines="8"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 VerticalScrollBarVisibility="Auto"
                 TextWrapping="Wrap"/>

        <!-- Row 1: Macros label -->
        <Label Grid.Row="1" Content="Macros:" Padding="0,0,0,2"/>

        <!-- Row 2: macro list -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Macros}"
                  SelectedItem="{Binding SelectedMacro, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  Margin="0,0,0,6"
                  MouseDoubleClick="OnMacroDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Macro" Binding="{Binding DisplayName}" Width="160"/>
                <DataGridTextColumn Header="Value" Binding="{Binding Value}"       Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Row 3: Insert Macro + OK / Cancel -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Content="Insert Macro"
                    MinWidth="100"
                    IsEnabled="{Binding CanInsertMacro}"
                    Click="OnInsertMacroClick"/>
            <Button Grid.Column="2"
                    Content="OK"
                    MinWidth="75"
                    IsDefault="True"
                    Click="OnOkClick"/>
            <Button Grid.Column="4"
                    Content="Cancel"
                    MinWidth="75"
                    IsCancel="True"/>
        </Grid>
    </Grid>
</Window>
