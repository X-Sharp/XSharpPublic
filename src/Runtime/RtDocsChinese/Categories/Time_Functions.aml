              </para>
            </entry>
            <entry>
              <para>
            Returns the seconds portion from a DateTime expression.
        </para>
            </entry>
          </row>
          <row>
            <entry>
              <para>XSharp.Core</para>
            </entry>
            <entry>
              <para>
                <codeEntityReference qualifyHint="false" autoUpgrade="true">M:XSharp.Core.Functions.Seconds</codeEntityReference>
              </para>
            </entry>
            <entry>
              <para>
